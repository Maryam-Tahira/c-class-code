/* Bitwise operator:



&(and) 1- 1 , 0 

, ^(xor)  0,1 1,0 - 1 11 00 -0,

` (or) 1- 0, 

~ (not), 

<< (left shift)  1010 -> 0100 , >> (right shift) 1010 -> 0101

*****************************************************/

#include <stdio.h>

int main()
{
    
    
    
    int a=5; //0101
    int b=3;//0011
    
    
    printf("%d\n",a&b);//(0101 & 0011) // 0001 =1
    
    printf("%d\n",a|b );//0111 =7 
    printf("%d\n",a^b ); //0110 = 6
    printf("%d\n",~b );//1010 
    
    printf("%d\n",b<<1 );//0110 
    
    printf("%d",b>>1 ); // 0001
    
    
    
    
    
    
    return 0;
}
