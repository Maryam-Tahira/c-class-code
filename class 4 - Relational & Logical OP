// Class -04 ---> Operators
#include <stdio.h>

int main() {
    // Relational Operator: ==,  > , < , >= , <= , !=
    int a=10, b=12;
    
    printf("%d\n",a==b);//0 
    printf("%d\n",a>b);//0
    printf("%d\n",a<b);//1
    printf("%d\n",a<=b);//1
    printf("%d\n",a>=b);//1
    printf("%d\n",a!=b);//1
    
    //Logical Operator: And - && , or - || , not - !
    //and - jodi amar shob true hoy tahole amar ans true otherwise false .
    printf("%d\n",0&&1);//0
    printf("%d\n",1&&0);//0
    printf("%d\n",0&&0);//0
    printf("%d\n",1&&1);//1
    printf("%d\n",(a<b)&&(a!=b));//1
    printf("%d\n",(a>b)&&(a!=b));// 0 && 1 ->0
    //or - amake true dile e hbe , 
    printf("%d\n",(a>b)||(a!=b));//1
    //not !
    printf("%d\n",!((a>b)||(a!=b)));//0
    printf("%d\n",!1);
    

    
    


    

    return 0;
}
