#include <iostream>
using namespace std;

class stu{
    public:
    string name;
    int id;
    
    stu(string n, int i)
    {
        name=n;
        id=i;
        cout<<"constructor called "<<name<<" "<<endl;
    }
    
    ~stu()
    {
        cout<<"dest called"<<endl;
    }
    
    void fun1()
    {
        cout<<"fun1 called  "<<name<<" "<<id<<endl;
    }
    
};
int main()
{
    stu s1("maryam",26711);
    stu s2("mim",26712);
    
    s1.fun1();
    
    

    return 0; // destructor called 
}
